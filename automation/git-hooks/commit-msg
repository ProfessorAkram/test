#!/bin/sh

# ---------------------------------------------------------
# 1. PREPARE COMMIT DATA
# ---------------------------------------------------------
# Git passes the path to the temporary commit message file as the first argument ($1)
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(head -n 1 "$COMMIT_MSG_FILE")

# ---------------------------------------------------------
# 2. DEFINE VALIDATION RULES
# ---------------------------------------------------------
# Allowed commit types based on the project's system architecture categories
TYPES="init|feat|fix|docs|refactor|test|chore|opt|build|revert|hotfix"

# Pattern: Starts with a type, followed by a colon and a space (e.g., feat: description)
PATTERN="^($TYPES): .+"

# ---------------------------------------------------------
# 3. ENFORCE MESSAGE FORMAT
# ---------------------------------------------------------
if ! echo "$COMMIT_MSG" | grep -Eq "$PATTERN"; then
  echo "===================================================="
  echo "❌ INVALID COMMIT MESSAGE FORMAT"
  echo "===================================================="
  echo "Expected format: <type>: <short description>"
  echo ""
  echo "Choose a type based on your intent:"
  echo "  init     - first-time setup or initialization"
  echo "  feat     - added new behavior, system, class, or content"
  echo "  fix      - fixed a bug, typo, broken logic, or placement"
  echo "  hotfix   - emergency or temporary fix"
  echo "  refactor - restructured code or scenes (no behavior change)"
  echo "  opt      - improved performance or efficiency"
  echo "  docs     - documentation or comments only"
  echo "  chore    - maintenance, cleanup, tooling, or assets"
  echo "  test     - added or updated tests or playtesting"
  echo "  build    - build system, CI, or export settings"
  echo "  revert   - undo a previous commit"
  echo ""
  echo "Examples:"
    echo "  feat: add player health bars"
    echo "  fix: correct enemy spawn location"
    echo "  refactor: reorganize AI scripts by behavior"
    echo "  docs: update README with setup instructions"
  echo "----------------------------------------------------"
  echo "Tip: Ask yourself — why does this commit exist?"
  echo "===================================================="
  exit 1
fi

exit 0